[alias]
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	ignore = "!gi() { curl -L -s https://www.gitignore.io/api/$@ ;}; gi"
[user]
    name = Srijan R Shetty
    email = srijan.shetty@gmail.com
[color]
	ui = 1
[apply]
    whitespace = fix
[core]
    excludesfile = /home/srijan/.gitignore_global
    attributesfile = ~/.gitattributes
    whitespace = fix,space-before-tab,tab-in-indent,trailing-space
	safecrlf = false
[color "branch"]
    current = yellow bold
    remote = red reverse
[color "diff"]
    meta = white bold
    frag = cyan
    old = red
    new = green
[color "status"]
    added = green
    changed = yellow
    untracked = red
[merge]
    log = true
[push]
    default = matching
[help]
	autocorrect = 0
[gist]
	home = /home/srijan/.gists
[hub]
	protocol = git
[credential]
	helper = cache --timeout=3600
